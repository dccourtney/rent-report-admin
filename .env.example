# Point at the SAME Supabase project as the main rent-report app.
# Copy the values from the main app's .env (local dev) or your hosting env (prod).

# Local dev against local Supabase stack:
#   VITE_SUPABASE_URL=http://localhost:54321
# Prod / hosted project:
#   VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
